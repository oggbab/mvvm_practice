<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Button
        android:id="@+id/btn_01"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#950F0F"
        android:text="btn01"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <Button
        android:id="@+id/btn_02"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#7C4DFF"
        android:text="btn02"
        android:layout_marginLeft="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/btn_01"
        />

        <Button
            android:id="@+id/btn_03"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#B2FF59"
            android:text="btn03"
            android:layout_marginLeft="20dp"
            app:layout_constraintTop_toBottomOf="@+id/btn_01"
            app:layout_constraintLeft_toLeftOf="@+id/btn_02"
        />


        <Button
            android:id="@+id/btn_04"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#B2FF59"
            android:text="btn03"
            android:layout_marginLeft="20dp"
            app:layout_constraintBaseline_toBaselineOf="@+id/btn_03"
            app:layout_constraintLeft_toLeftOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>
